@model IEnumerable<TMS201.Models.Client>
@{
    ViewData["Title"] = "Client Management";
}

<link href="~/css/Client.css" rel="stylesheet" />


<style>


</style>
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>

        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb small">
                <li class="breadcrumb-item">
                    <a asp-controller="Ticket" asp-action="Index" class="text-decoration-none text-info">
                        Tickets
                    </a>
                </li>
                <li class="breadcrumb-item active text-light" aria-current="page">
                    Client Master
                </li>
            </ol>
        </nav>

        <h3 class="fw-bold text-white mb-1">
            <i class="bi bi-building-fill me-2 text-primary"></i>Client Master
        </h3>

        <p class="text-muted small mb-0">
            List of all registered clients and their details.
        </p>

    </div>

    <button class="btn btn-primary d-flex align-items-center gap-2 px-4 shadow-sm"
            data-bs-toggle="modal"
            data-bs-target="#addClientModal">
        <i class="bi bi-plus-lg"></i>
        <span>Add New Client</span>
    </button>
</div>

    <div class="client-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Client Name</th>
                        <th>Contact Person</th>
                        <th>Email Address</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-database-exclamation fs-1 text-muted d-block mb-3"></i>
                                <span class="text-muted">No clients found in the database.</span>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-white">@item.Name</div>
                                <div class="text-muted" style="font-size: 0.7rem;">ID: #@item.Id</div>
                            </td>
                            <td>@(string.IsNullOrEmpty(item.ContactPerson) ? "—" : item.ContactPerson)</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Email))
                                {
                                    <span class="text-info"><i class="bi bi-envelope me-1"></i>@item.Email</span>
                                }
                                else
                                {
                                    <span class="text-muted small text-white-50">Not provided</span>
                                }
                            </td>
                            <td>
                                <span class="badge @(item.IsActive ? "badge-active" : "badge-inactive") px-3 py-2 rounded-pill">
                                    <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>
                                    @(item.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="text-center">
                        <div class="dropdown">
                            <button class="btn btn-sm border-0 text-light opacity-75" 
                                    type="button" 
                                    data-bs-toggle="dropdown" 
                                    aria-expanded="false"
                                    style="cursor: pointer;">
                                <i class="bi bi-three-dots-vertical fs-5"></i>
                            </button>
        
                            <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow-lg border-secondary">
                                            <li>
                                                <a class="dropdown-item py-2" href="javascript:void(0)" onclick="loadClientDetails(@item.Id)">
                                                    <i class="bi bi-pencil-square me-2 text-info"></i>Edit Details
                                                </a>
                                            </li>
                                <li><hr class="dropdown-divider border-secondary"></li>
                                <li>
                                    <form asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete this client?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="dropdown-item py-2 text-danger">
                                            <i class="bi bi-trash3 me-2"></i>Remove Client
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                     </td>
                  </tr>
                }
                </tbody>
            </table>
        </div>


         @* 🔥 PAGINATION CALLED FROM PARTIAL FILE *@
        <partial name="_Pagination" />
    </div>
</div>

<div class="modal fade" id="addClientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content dark-modal-content shadow-lg">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header dark-modal-header">
                    <h5 class="modal-title text-white fw-bold">Register New Client</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase">Client / Company Name <span class="text-danger">*</span></label>
                        <input name="Name" class="form-control form-control-dark py-2" placeholder="e.g. Acme Corp" required autocomplete="off" />
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase">Contact Person (Optional)</label>
                        <input name="ContactPerson" class="form-control form-control-dark py-2" placeholder="Name of point person" autocomplete="off" />
                    </div>
                    
                    <div class="mb-2">
                        <label class="form-label text-muted small fw-bold text-uppercase">Email Address (Optional)</label>
                        <input name="Email" type="email" class="form-control form-control-dark py-2" placeholder="email@company.com" autocomplete="off" />
                    </div>
                </div>
                <div class="modal-footer dark-modal-footer">
                    <button type="button" class="btn btn-outline-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm px-4 fw-bold">Register</button>
                </div>
            </form>
        </div>
    </div>
</div>


<div class="modal fade" id="editClientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content dark-modal-content shadow-lg">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="Id" />
                
                <div class="modal-header dark-modal-header">
                    <h5 class="modal-title text-white fw-bold">Edit Client Details</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase">Client Name *</label>
                        <input id="editName" name="Name" class="form-control form-control-dark py-2" required />
                    </div>
                    
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold text-uppercase">Contact Person</label>
                        <input id="editContact" name="ContactPerson" class="form-control form-control-dark py-2" />
                    </div>
                    
                    <div class="mb-2">
                        <label class="form-label text-muted small fw-bold text-uppercase">Email Address</label>
                        <input id="editEmail" name="Email" type="email" class="form-control form-control-dark py-2" />
                    </div>
                </div>
                <div class="modal-footer dark-modal-footer">
                    <button type="button" class="btn btn-outline-secondary btn-sm px-4" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-info btn-sm px-4 fw-bold text-white">Update Client</button>
                </div>
            </form>
        </div>
    </div>
</div>

 <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
 <script src="~/js/client-index.js"></script>