@model IEnumerable<TMS201.Models.TicketAttachment>

<style>
    .custom-page-wrapper {
        width: 100%;
        overflow-x: hidden;
    }
    .table-scroll-container {
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border-radius: 8px;
    }
    .table {
        min-width: 800px;
        margin-bottom: 0;
    }
    /* File name truncate logic */
    .file-name-cell {
        max-width: 180px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* --- MOBILE RESPONSIVE MODAL (THE "GAP" FIX) --- */
    @@media (max-width: 576px) {
        #uploadModal .modal-dialog {
            display: flex;
            align-items: center;
            min-height: calc(100% - 1rem); /* Center alignment fix */
            margin: 1.5rem auto; /* Top-Bottom margin */
            width: 88% !important; /* Yahi hai left-right space ka magic */
            max-width: 380px; /* Zyada bada hone se rokega */
        }
        #uploadModal .modal-content {
            border-radius: 16px; /* Rounded corners for premium look */
            border: none;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        }
        .modal-header { padding: 1rem; }
        .modal-body { padding: 1.5rem 1.2rem; }
        h2 { font-size: 1.25rem !important; }
    }
</style>

<div class="container mt-4 custom-page-wrapper">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h2 class="fw-bold text-primary m-0">
            <i class="bi bi-folder2-open"></i> Attachments #@ViewBag.TicketId
        </h2>
        
        <div class="d-flex gap-2">
            @* Mobile icons only *@
            <button type="button" class="btn btn-success rounded-pill px-3 px-sm-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#uploadModal">
                <i class="bi bi-plus-circle"></i> <span class="d-none d-sm-inline ms-1">Add More</span>
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3 shadow-sm d-flex align-items-center">
                <i class="bi bi-arrow-left"></i> <span class="d-none d-sm-inline ms-1">Back</span>
            </a>
        </div>
    </div>

    @* --- Table Section --- *@
    <div class="card shadow-sm border-0">
        <div class="card-body p-0"> 
            <div class="table-scroll-container">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">File Name</th>
                            <th>Format</th>
                            <th>Uploaded Date</th>
                            <th class="text-center pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var type = item.FileType.ToLower();
                            
                            // Simplification of complex MIME types
                            string displayFormat = type.Split('/').Last().ToUpper();
                            if (type.Contains("spreadsheet") || type.Contains("excel")) displayFormat = "EXCEL";
                            else if (type.Contains("word") || type.Contains("officedocument.word")) displayFormat = "WORD";

                            bool isOffice = type.Contains("spreadsheet") || type.Contains("excel") || type.Contains("officedocument") || type.Contains("word");
                            
                            <tr>
                                <td class="ps-3">
                                    <div class="file-name-cell fw-bold" title="@item.FileName">
                                        @item.FileName
                                    </div>
                                </td>
                                <td><span class="badge bg-secondary">@displayFormat</span></td>
                                <td>@item.UploadedDate.ToString("dd-MMM-yyyy")</td>
                                <td class="text-center pe-3">
                                    <div class="btn-group">
                                        @if (!isOffice)
                                        {
                                            <button class="btn btn-sm btn-outline-primary" title="Preview"
                                                    onclick="showPreview('@item.FilePath', '@type', '@item.FileName')">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                        }
                                        <a href="@item.FilePath" download="@item.FileName" class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-download"></i>
                                        </a>
                                        <form asp-action="DeleteAttachment" method="post" class="d-inline" onsubmit="return confirm('Bhai, pakka delete karna hai?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* --- PERFECT RESPONSIVE UPLOAD MODAL --- *@
<div class="modal fade" id="uploadModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-success text-white py-2">
                <h6 class="modal-title fw-bold"><i class="bi bi-cloud-arrow-up-fill me-2"></i>Upload</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            
            <form asp-action="UploadAttachment" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="ticketId" value="@ViewBag.TicketId" />
                    
                    <div class="p-3 border border-2 border-dashed rounded-3 bg-light text-center">
                        <label class="form-label fw-bold small text-secondary mb-2 d-block">Choose Files</label>
                        <input type="file" name="attachments" class="form-control form-control-sm shadow-sm" multiple required />
                    </div>
                </div>
                
                <div class="modal-footer border-0 pt-0">
                    <button type="submit" class="btn btn-success w-100 rounded-pill fw-bold py-2 shadow-sm">
                        Upload Now
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* --- Preview Modal (Standard XL) --- *@
<div class="modal fade" id="previewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-dark text-white p-2">
                <h6 class="modal-title" id="modalFileName">File Preview</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-0" style="background: #1e293b; min-height: 400px; display: flex; align-items: center; justify-content: center;">
                <div id="previewContent" style="width: 100%;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ticket-view-attachments.js"></script>
}