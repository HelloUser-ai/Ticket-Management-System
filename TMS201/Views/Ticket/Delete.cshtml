@model Ticket

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">

    <div class="card shadow-lg border-0" style="max-width: 500px; width: 100%; border-radius: 15px;">

        <div class="card-header bg-danger text-white text-center" style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
            <h4 class="mb-0">⚠️ Confirm Delete</h4>
        </div>

        <div class="card-body text-center p-4">

            <div class="mb-3">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 40px;"></i>
            </div>

            <h5 class="mb-3 text-danger">Are you sure you want to delete this ticket?</h5>

            <div class="text-start mb-3">
                <p><b>Ticket No:</b> @Model.TicketNo</p>
                <p><b>Task:</b> @Model.TaskDetails</p>
            </div>

            <form asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <button type="submit" class="btn btn-danger w-100 mb-2">
                    <i class="bi bi-trash"></i> Yes, Delete
                </button>

                <a asp-action="Index" class="btn btn-outline-secondary w-100">
                    Cancel
                </a>
            </form>

        </div>

    </div>

</div>
