@model Ticket
@inject IHttpContextAccessor HttpContextAccessor
@{
    var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
    ViewData["Title"] = Model.Id == 0 ? "Create Ticket" : "Edit Ticket";
}

<style>
    .upload-area {
        border: 2px dashed rgba(255, 255, 255, 0.2);
        border-radius: 15px;
        padding: 20px;
        text-align: center;
        transition: 0.3s;
        cursor: pointer;
        background: rgba(15, 23, 42, 0.4);
    }
    .upload-area:hover { border-color: #3b82f6; background: rgba(59, 130, 246, 0.1); }
    .file-preview-item {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
        padding: 8px 15px;
        margin-top: 10px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .btn-remove { color: #ef4444; cursor: pointer; }

    /* 🎨 Glassmorphism Card Effect */
    .ticket-card {
        background: rgba(30, 41, 59, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 20px;
        padding: 30px;
        color: white;
    }

    /* Input Fields Styling */
    .form-label {
        font-weight: 500;
        color: #cbd5f5;
        margin-bottom: 8px;
        font-size: 0.9rem;
    }

    .form-control, .form-select {
        background-color: rgba(15, 23, 42, 0.8) !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: white !important;
        border-radius: 10px;
        padding: 10px 15px;
    }

    .form-control:focus, .form-select:focus {
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.25);
    }

    select option {
        background-color: #1e293b;
        color: white;
    }

    .form-control[readonly] {
        background-color: rgba(15, 23, 42, 0.5) !important;
        opacity: 0.7;
    }

    .btn-save {
        background: linear-gradient(135deg, #22c55e, #15803d);
        border: none;
        padding: 10px 30px;
        font-weight: 600;
        border-radius: 10px;
        transition: 0.3s;
    }

    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(34, 197, 94, 0.4);
    }

    @@media (max-width: 768px) {
        .ticket-card { padding: 20px; margin: 0 10px; }
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <div class="ticket-card shadow-lg">
                
                <div class="text-center mb-4">
                    <div class="d-inline-block p-3 bg-primary bg-opacity-10 rounded-circle mb-3">
                        <i class="bi bi-ticket-perforated fs-1 text-primary"></i>
                    </div>
                    <h3 class="fw-bold">@ViewData["Title"]</h3>
                    <p class="text-muted small">Please fill in the details below to @(Model.Id == 0 ? "create a new" : "update the") ticket.</p>
                </div>

                <hr class="border-secondary opacity-25 mb-4">

                <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="TicketDate" />
                    <input type="hidden" asp-for="TicketNo" />

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger border-0 rounded-3 mb-4">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> Please correct the errors below.
                            <div asp-validation-summary="All" class="small mt-1"></div>
                        </div>
                    }

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-calendar-event me-2 text-primary"></i>Ticket Date</label>
                            <input class="form-control" value="@Model.TicketDate.ToString("dd-MM-yyyy")" readonly />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-building me-2 text-primary"></i>Client Name</label>
                            <select asp-for="ClientName" class="form-select">
                                <option value="">Select Client</option>
                                @foreach (var item in ViewBag.ClientList ?? new List<string>())
                                {
                                    <option value="@item" selected="@(item == Model.ClientName)">@item</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-diagram-3 me-2 text-primary"></i>Plant Name</label>
                            <select asp-for="PlantName" class="form-select">
                                <option value="">Select Plant</option>
                                @foreach (var item in ViewBag.PlantNames ?? new List<string>())
                                {
                                    <option value="@item" selected="@(item == Model.PlantName)">@item</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-layers me-2 text-primary"></i>Module Type</label>
                            <select asp-for="PlantType" class="form-select">
                                <option value="">Select Type</option>
                                @foreach (var item in ViewBag.PlantTypes ?? new List<string>())
                                {
                                    <option value="@item" selected="@(item == Model.PlantType)">@item</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-person me-2 text-primary"></i>Given By</label>
                            <input asp-for="GivenBy" class="form-control" placeholder="Enter Given By" />
                        </div>

                        @if (role != "Admin")
                        {
                            <div class="col-md-6">
                                <label class="form-label"><i class="bi bi-person-check me-2 text-primary"></i>Assigned To</label>
                                <select asp-for="AssignedTo" class="form-select">
                                    <option value="">Select Employee</option>
                                    @foreach (var emp in ViewBag.AssignedToList ?? new List<string>())
                                    {
                                        <option value="@emp" selected="@(emp == Model.AssignedTo)">@emp</option>
                                    }
                                </select>
                            </div>
                        }

                        <div class="col-md-6">
                            <label class="form-label"><i class="bi bi-flag me-2 text-primary"></i>Status</label>
                            @if (Model.Id == 0)
                            {
                                <input type="text" class="form-control" value="Pending" readonly />
                                <input type="hidden" asp-for="TicketStatus" value="Pending" />
                            }
                            else
                            {
                                <select asp-for="TicketStatus" class="form-select">
                                    @{
                                        var employeeOptions = new[] { "Pending", "Completed" };
                                        var adminOptions = new[] { "Pending", "Completed", "No Issue" };
                                        var superAdminOptions = new[] { "Pending", "In Progress", "Completed", "In Testing Phase", "In Dev Phase", "Pending from Client", "No Issue" };

                                        string[] currentAllowedOptions;
                                        if (role == "SuperAdmin") currentAllowedOptions = superAdminOptions;
                                        else if (role == "Admin") currentAllowedOptions = adminOptions;
                                        else currentAllowedOptions = employeeOptions;

                                        if (!currentAllowedOptions.Contains(Model.TicketStatus) && !string.IsNullOrEmpty(Model.TicketStatus))
                                        {
                                            <option value="@Model.TicketStatus" selected="selected" disabled>@Model.TicketStatus</option>
                                        }

                                        foreach (var opt in currentAllowedOptions)
                                        {
                                            <option value="@opt" selected="@(Model.TicketStatus == opt)">@opt</option>
                                        }
                                    }
                                </select>
                            }
                        </div>

                        <div class="col-12 mt-4">
                            <label class="form-label"><i class="bi bi-paperclip me-2 text-primary"></i>Attachments</label>
                            <div class="upload-area" onclick="document.getElementById('fileInput').click()">
                                <i class="bi bi-cloud-arrow-up fs-2 text-primary"></i>
                                <p class="mb-0">Click or Drag & Drop files here</p>
                                <span class="text-muted small">Supports Images, Video, Audio, Docs, Zip</span>
                                <input type="file" name="attachments" id="fileInput" class="d-none" multiple onchange="handleFileSelect(this)" />
                            </div>
                            <div id="filePreviewList" class="mt-3"></div>
                        </div>

                        <div class="col-12">
                            <label class="form-label"><i class="bi bi-card-text me-2 text-primary"></i>Task Details</label>
                            <textarea asp-for="TaskDetails" class="form-control" rows="4" placeholder="Describe the task or issue here..."></textarea>
                        </div>
                    </div>

                    <div class="d-flex flex-column flex-md-row justify-content-center gap-3 mt-5">
                        <button type="submit" class="btn btn-save text-white">
                            <i class="bi bi-check2-circle me-2"></i>Save Ticket
                        </button>
                        <a asp-action="Index" class="btn btn-outline-light border-0 px-4">
                            <i class="bi bi-x-circle me-2"></i>Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

<script src="~/js/ticket-create.js"></script>