@model Ticket

<div class="container-fluid">

    <div class="card shadow border-0 text-white" style="background:#1e293b;">

        <!-- HEADER -->
        <div class="card-header d-flex justify-content-between align-items-center"
             style="background:#2563eb;">
            <h5 class="mb-0 fw-semibold">Ticket Details</h5>
            <span class="badge bg-light text-dark px-3 py-2">#@Model.TicketNo</span>
        </div>

        <div class="card-body">

            <div class="row">

                <!-- 🔵 LEFT SIDE -->
                <div class="col-md-6 border-end" style="border-color:#334155 !important;">

                    <div class="mb-3">
                        <small class="text-light-emphasis">Date</small>
                        <div class="fw-semibold">@Model.TicketDate.ToString("dd-MM-yyyy")</div>
                    </div>

                    <div class="mb-3">
                        <small class="text-light-emphasis">Client</small>
                        <div class="fw-semibold">@Model.ClientName</div>
                    </div>

                    <div class="mb-3">
                        <small class="text-light-emphasis">Plant</small>
                        <div class="fw-semibold">@Model.PlantName</div>
                    </div>

                    <div class="mb-3">
                        <small class="text-light-emphasis">Type</small>
                        <div>
                            <span class="badge bg-dark px-3 py-2">@Model.PlantType</span>
                        </div>
                    </div>

                </div>

                <!-- 🟢 RIGHT SIDE -->
                <div class="col-md-6">

                    <div class="mb-3">
                        <small class="text-light-emphasis">Given By</small>
                        <div class="fw-semibold">@Model.GivenBy</div>
                    </div>

                    <div class="mb-3">
                        <small class="text-light-emphasis">Assigned To</small>
                        <div>
                            <span class="badge bg-secondary px-3 py-2">
                                @Model.AssignedTo
                            </span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <small class="text-light-emphasis">Status</small>
                        <div>
                            @{
                                var config = Model.TicketStatus switch
                                {
                                    "Pending" => "bg-warning text-dark",
                                    "In Progress" => "bg-info text-white",
                                    "Completed" => "bg-success text-white",
                                    "In Testing Phase" => "bg-primary text-white",
                                    "In Dev Phase" => "bg-dark text-white",
                                    "Pending from Client" => "bg-danger text-white",
                                    "No Issue" => "bg-secondary text-white",
                                    _ => "bg-light text-dark"
                                };
                            }

                            <span class="badge rounded-pill px-3 py-2 @config">
                                @Model.TicketStatus
                            </span>
                        </div>
                    </div>

                </div>

            </div>

            <!-- 🔥 BIG TASK DETAILS -->
            <div class="mt-4">
                <small class="text-light-emphasis">Task Details</small>

                <div class="mt-2 p-4 rounded"
                     style="
                    background:#0f172a;
                    border:1px solid #334155;
                    min-height:200px;
                    max-height:350px;
                    overflow-y:auto;
                    white-space:pre-line;
                    line-height:1.6;
                    ">
                    @Model.TaskDetails
                </div>
            </div>

            <!-- 🧾 AUDIT -->
            <div class="row mt-4 pt-3" style="border-top:1px solid #334155;">

                <div class="col-md-6">
                    <small class="text-light-emphasis">Created By</small>
                    <div class="fw-semibold">@Model.CreatedBy</div>
                    <div class="text-muted small">
                        @(Model.CreatedDate?.ToString("dd-MM-yyyy HH:mm") ?? "-")
                    </div>
                </div>

                <div class="col-md-6">
                    <small class="text-light-emphasis">Updated By</small>
                    <div class="fw-semibold">
                        @(string.IsNullOrEmpty(Model.UpdatedBy) ? "-" : Model.UpdatedBy)
                    </div>
                    <div class="text-muted small">
                        @(Model.UpdatedDate?.ToString("dd-MM-yyyy HH:mm") ?? "-")
                    </div>
                </div>

            </div>

        </div>

        <!-- FOOTER -->
        <div class="card-footer d-flex justify-content-between"
             style="background:#020617; border-top:1px solid #334155;">

            <a asp-action="Index" class="btn btn-outline-light btn-sm">
                <i class="bi bi-arrow-left"></i> Back
            </a>

            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-primary btn-sm">
                    <i class="bi bi-pencil"></i> Edit
                </a>

                <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Delete this ticket?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger btn-sm">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </form>
            </div>

        </div>

    </div>

</div>
