@model IEnumerable<TMS201.Models.User>
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="m-0">👥 Users</h2>
        <a asp-controller="Account" asp-action="Add" class="btn btn-success shadow-sm">
            <i class="bi bi-person-plus-fill me-2"></i> Add New User
        </a>
    </div>

    <div class="card bg-dark text-white p-3 mb-4 border-secondary">
        <h5 class="m-0">Total Users: <span class="text-success">@ViewBag.TotalUsers</span></h5>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover table-dark align-middle">
            <thead class="table-secondary text-dark text-center">
                <tr>
                    <th style="width: 80px;">SR</th>
                    <th>UserName</th>
                    <th>Password</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody class="text-center">
                @if (Model != null && Model.Any())
                {
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td class="fw-bold">@user.Username</td>
                            <td>
                                <span class="text-white-50">@user.Password</span>
                            </td>
                            <td>
                                @{
                                    var badgeClass = user.Role?.ToLower() switch
                                    {
                                        "admin" => "bg-danger",
                                        "superadmin" => "bg-warning text-dark",
                                        "employee" => "bg-info text-dark",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badgeClass" style="min-width: 100px;">
                                    <i class="bi bi-shield-lock me-1"></i> @user.Role
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted">No users found.</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-3">
            <a asp-controller="Ticket" asp-action="Index" class="btn btn-outline-light">
                <i class="bi bi-arrow-left me-2"></i> Back to Tickets
            </a>
        </div>

        @* 🔥 PAGINATION *@
        <div class="mt-4">
            <partial name="_Pagination" />
        </div>

    </div>
</div>